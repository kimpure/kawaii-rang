var new_class = class() {

}

var new_class = class(a: string, b, c) {

}

var new_class = class(a="apple", b: string="banana", c) {

}

var new_class = class {
    self = {
        a = a,
        b = b,
    }

    function print_self(self: Self, p: string) {
        print(self.a, self.b, p)
    }
}
